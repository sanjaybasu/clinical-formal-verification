{
  "id": "triagepartial-d3-viol-02",
  "domain": "triage_partial",
  "metadata": {
    "description": "partial-context triage; missing critical data must not be reassuring",
    "source": "synthetic",
    "clinical_intent": "marking the vitals unknown never lowers the assigned acuity"
  },
  "ruleset": {
    "id": "tmd-3-2",
    "kind": "decision",
    "inputs": [
      {
        "name": "vitals_unknown",
        "type": "bool"
      },
      {
        "name": "concerning_symptom",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "headache",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "concerning_urgent",
        "priority": 10,
        "when": {
          "var": "concerning_symptom"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "unknown_defers",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "vitals_unknown"
            },
            {
              "var": "rash"
            },
            {
              "var": "headache"
            }
          ]
        },
        "then": [
          {
            "var": "acuity",
            "value": "self_care"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "missing-data-not-reassuring",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "vitals_unknown",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting vitals_unknown true never lowers acuity"
  }
}
