{
  "id": "workup-d3-hold-101",
  "domain": "workup_completeness",
  "metadata": {
    "description": "workup completeness; mandatory workup for a sentinel presentation is not omitted",
    "source": "synthetic",
    "clinical_intent": "a neonate-fever sentinel presentation must order the full sepsis workup"
  },
  "ruleset": {
    "id": "wk-3-101",
    "kind": "decision",
    "inputs": [
      {
        "name": "lethargy",
        "type": "bool"
      },
      {
        "name": "irritable",
        "type": "bool"
      },
      {
        "name": "poor_feeding",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "full_sepsis_workup",
        "type": "bool"
      }
    ],
    "rules": [
      {
        "id": "order_sepsis_workup",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "lethargy"
            },
            {
              "var": "irritable"
            },
            {
              "var": "poor_feeding"
            }
          ]
        },
        "then": [
          {
            "var": "full_sepsis_workup",
            "value": true
          }
        ]
      }
    ],
    "default": [
      {
        "var": "full_sepsis_workup",
        "value": false
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "mandatory-workup-not-omitted",
    "kind": "invariant",
    "formula": {
      "op": "implies",
      "args": [
        {
          "op": "and",
          "args": [
            {
              "var": "lethargy"
            },
            {
              "var": "irritable"
            },
            {
              "var": "poor_feeding"
            }
          ]
        },
        {
          "var": "full_sepsis_workup"
        }
      ]
    },
    "intent": "when the sentinel antecedents hold, the mandatory workup is ordered"
  }
}
