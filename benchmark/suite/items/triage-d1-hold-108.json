{
  "id": "triage-d1-hold-108",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-1-108",
    "kind": "decision",
    "inputs": [
      {
        "name": "severe_headache",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "chest_pain",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_rash",
        "priority": 2,
        "when": {
          "var": "rash"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_chest_pain",
        "priority": 2,
        "when": {
          "var": "chest_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "severe_headache",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting severe_headache true never lowers acuity"
  }
}
