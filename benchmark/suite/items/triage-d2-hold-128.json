{
  "id": "triage-d2-hold-128",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-2-128",
    "kind": "decision",
    "inputs": [
      {
        "name": "dizziness",
        "type": "bool"
      },
      {
        "name": "confusion",
        "type": "bool"
      },
      {
        "name": "syncope",
        "type": "bool"
      },
      {
        "name": "slurred_speech",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_syncope",
        "priority": 2,
        "when": {
          "var": "syncope"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_dizziness",
        "priority": 2,
        "when": {
          "var": "dizziness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_slurred_speech",
        "priority": 3,
        "when": {
          "var": "slurred_speech"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "confusion",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting confusion true never lowers acuity"
  }
}
