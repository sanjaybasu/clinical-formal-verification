{
  "id": "medication-d12-viol-00",
  "domain": "medication",
  "metadata": {
    "description": "condition-to-recommendation rules; a contraindicated pair must not co-occur",
    "source": "synthetic",
    "clinical_intent": "drugs a and b form a contraindicated pair and must never be jointly recommended"
  },
  "ruleset": {
    "id": "medication-12-0",
    "kind": "decision",
    "inputs": [
      {
        "name": "prior_gi_bleed",
        "type": "bool"
      },
      {
        "name": "g6pd_deficiency",
        "type": "bool"
      },
      {
        "name": "hepatic_impairment",
        "type": "bool"
      },
      {
        "name": "heart_failure",
        "type": "bool"
      },
      {
        "name": "anticoagulated",
        "type": "bool"
      },
      {
        "name": "hyperkalemia",
        "type": "bool"
      },
      {
        "name": "low_ejection_fraction",
        "type": "bool"
      },
      {
        "name": "ckd_dialysis",
        "type": "bool"
      },
      {
        "name": "diabetes",
        "type": "bool"
      },
      {
        "name": "qt_prolongation",
        "type": "bool"
      },
      {
        "name": "asthma",
        "type": "bool"
      },
      {
        "name": "seizure_history",
        "type": "bool"
      },
      {
        "name": "peptic_ulcer",
        "type": "bool"
      },
      {
        "name": "elderly",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "rec_drug_a",
        "type": "bool"
      },
      {
        "name": "rec_drug_b",
        "type": "bool"
      },
      {
        "name": "rec_drug_c",
        "type": "bool"
      }
    ],
    "rules": [
      {
        "id": "rec_c_from_elderly",
        "priority": 40,
        "when": {
          "var": "elderly"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_b_from_trigger",
        "priority": 50,
        "when": {
          "var": "prior_gi_bleed"
        },
        "then": [
          {
            "var": "rec_drug_b",
            "value": true
          }
        ]
      },
      {
        "id": "rec_c_from_peptic_ulcer",
        "priority": 40,
        "when": {
          "var": "peptic_ulcer"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_a_from_conjunction",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "prior_gi_bleed"
            },
            {
              "var": "g6pd_deficiency"
            },
            {
              "var": "hepatic_impairment"
            },
            {
              "var": "heart_failure"
            },
            {
              "var": "anticoagulated"
            },
            {
              "var": "hyperkalemia"
            },
            {
              "var": "low_ejection_fraction"
            },
            {
              "var": "ckd_dialysis"
            },
            {
              "var": "diabetes"
            },
            {
              "var": "qt_prolongation"
            },
            {
              "var": "asthma"
            },
            {
              "var": "seizure_history"
            }
          ]
        },
        "then": [
          {
            "var": "rec_drug_a",
            "value": true
          }
        ]
      }
    ],
    "default": [
      {
        "var": "rec_drug_a",
        "value": false
      },
      {
        "var": "rec_drug_b",
        "value": false
      },
      {
        "var": "rec_drug_c",
        "value": false
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "no-contraindicated-pair",
    "kind": "mutual_exclusion",
    "mutual_exclusion": {
      "pairs": [
        [
          {
            "var": "rec_drug_a"
          },
          {
            "var": "rec_drug_b"
          }
        ]
      ]
    },
    "intent": "no input recommends both drug a and drug b"
  }
}
