{
  "id": "triage-d3-hold-120",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-3-120",
    "kind": "decision",
    "inputs": [
      {
        "name": "vision_loss",
        "type": "bool"
      },
      {
        "name": "focal_weakness",
        "type": "bool"
      },
      {
        "name": "back_pain",
        "type": "bool"
      },
      {
        "name": "pallor",
        "type": "bool"
      },
      {
        "name": "leg_swelling",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_leg_swelling",
        "priority": 2,
        "when": {
          "var": "leg_swelling"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_focal_weakness",
        "priority": 3,
        "when": {
          "var": "focal_weakness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_pallor",
        "priority": 3,
        "when": {
          "var": "pallor"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_vision_loss",
        "priority": 2,
        "when": {
          "var": "vision_loss"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "back_pain",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting back_pain true never lowers acuity"
  }
}
