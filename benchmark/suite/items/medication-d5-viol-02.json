{
  "id": "medication-d5-viol-02",
  "domain": "medication",
  "metadata": {
    "description": "condition-to-recommendation rules; a contraindicated pair must not co-occur",
    "source": "synthetic",
    "clinical_intent": "drugs a and b form a contraindicated pair and must never be jointly recommended"
  },
  "ruleset": {
    "id": "medication-5-2",
    "kind": "decision",
    "inputs": [
      {
        "name": "hepatic_impairment",
        "type": "bool"
      },
      {
        "name": "hyperkalemia",
        "type": "bool"
      },
      {
        "name": "low_ejection_fraction",
        "type": "bool"
      },
      {
        "name": "pregnancy",
        "type": "bool"
      },
      {
        "name": "elderly",
        "type": "bool"
      },
      {
        "name": "bradycardia",
        "type": "bool"
      },
      {
        "name": "heart_failure",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "rec_drug_a",
        "type": "bool"
      },
      {
        "name": "rec_drug_b",
        "type": "bool"
      },
      {
        "name": "rec_drug_c",
        "type": "bool"
      }
    ],
    "rules": [
      {
        "id": "rec_b_from_trigger",
        "priority": 50,
        "when": {
          "var": "hepatic_impairment"
        },
        "then": [
          {
            "var": "rec_drug_b",
            "value": true
          }
        ]
      },
      {
        "id": "rec_c_from_bradycardia",
        "priority": 40,
        "when": {
          "var": "bradycardia"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_c_from_heart_failure",
        "priority": 40,
        "when": {
          "var": "heart_failure"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_a_from_conjunction",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "hepatic_impairment"
            },
            {
              "var": "hyperkalemia"
            },
            {
              "var": "low_ejection_fraction"
            },
            {
              "var": "pregnancy"
            },
            {
              "var": "elderly"
            }
          ]
        },
        "then": [
          {
            "var": "rec_drug_a",
            "value": true
          }
        ]
      }
    ],
    "default": [
      {
        "var": "rec_drug_a",
        "value": false
      },
      {
        "var": "rec_drug_b",
        "value": false
      },
      {
        "var": "rec_drug_c",
        "value": false
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "no-contraindicated-pair",
    "kind": "mutual_exclusion",
    "mutual_exclusion": {
      "pairs": [
        [
          {
            "var": "rec_drug_a"
          },
          {
            "var": "rec_drug_b"
          }
        ]
      ]
    },
    "intent": "no input recommends both drug a and drug b"
  }
}
