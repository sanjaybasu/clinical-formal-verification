{
  "id": "triage-d1-viol-01",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-1-1",
    "kind": "decision",
    "inputs": [
      {
        "name": "fever",
        "type": "bool"
      },
      {
        "name": "leg_swelling",
        "type": "bool"
      },
      {
        "name": "abdominal_pain",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "interaction_drop",
        "priority": 100,
        "when": {
          "var": "fever"
        },
        "then": [
          {
            "var": "acuity",
            "value": "self_care"
          }
        ]
      },
      {
        "id": "raise_abdominal_pain",
        "priority": 2,
        "when": {
          "var": "abdominal_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_leg_swelling",
        "priority": 3,
        "when": {
          "var": "leg_swelling"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "fever",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting fever true never lowers acuity"
  }
}
