{
  "id": "triage-d3-viol-01",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-3-1",
    "kind": "decision",
    "inputs": [
      {
        "name": "palpitations",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "chest_pain",
        "type": "bool"
      },
      {
        "name": "dizziness",
        "type": "bool"
      },
      {
        "name": "focal_weakness",
        "type": "bool"
      },
      {
        "name": "hemoptysis",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_rash",
        "priority": 3,
        "when": {
          "var": "rash"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_hemoptysis",
        "priority": 2,
        "when": {
          "var": "hemoptysis"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_palpitations",
        "priority": 2,
        "when": {
          "var": "palpitations"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "interaction_drop",
        "priority": 100,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "palpitations"
            },
            {
              "var": "rash"
            },
            {
              "var": "chest_pain"
            }
          ]
        },
        "then": [
          {
            "var": "acuity",
            "value": "self_care"
          }
        ]
      },
      {
        "id": "raise_dizziness",
        "priority": 3,
        "when": {
          "var": "dizziness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_focal_weakness",
        "priority": 2,
        "when": {
          "var": "focal_weakness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "chest_pain",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting chest_pain true never lowers acuity"
  }
}
