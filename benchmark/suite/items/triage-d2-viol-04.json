{
  "id": "triage-d2-viol-04",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-2-4",
    "kind": "decision",
    "inputs": [
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "hemoptysis",
        "type": "bool"
      },
      {
        "name": "palpitations",
        "type": "bool"
      },
      {
        "name": "vision_loss",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_rash",
        "priority": 2,
        "when": {
          "var": "rash"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_vision_loss",
        "priority": 2,
        "when": {
          "var": "vision_loss"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "interaction_drop",
        "priority": 100,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "rash"
            },
            {
              "var": "hemoptysis"
            }
          ]
        },
        "then": [
          {
            "var": "acuity",
            "value": "self_care"
          }
        ]
      },
      {
        "id": "raise_palpitations",
        "priority": 2,
        "when": {
          "var": "palpitations"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "hemoptysis",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting hemoptysis true never lowers acuity"
  }
}
