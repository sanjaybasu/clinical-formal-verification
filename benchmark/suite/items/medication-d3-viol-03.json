{
  "id": "medication-d3-viol-03",
  "domain": "medication",
  "metadata": {
    "description": "condition-to-recommendation rules; a contraindicated pair must not co-occur",
    "source": "synthetic",
    "clinical_intent": "drugs a and b form a contraindicated pair and must never be jointly recommended"
  },
  "ruleset": {
    "id": "medication-3-3",
    "kind": "decision",
    "inputs": [
      {
        "name": "polypharmacy",
        "type": "bool"
      },
      {
        "name": "heart_failure",
        "type": "bool"
      },
      {
        "name": "elderly",
        "type": "bool"
      },
      {
        "name": "renal_impairment",
        "type": "bool"
      },
      {
        "name": "anticoagulated",
        "type": "bool"
      },
      {
        "name": "qt_prolongation",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "rec_drug_a",
        "type": "bool"
      },
      {
        "name": "rec_drug_b",
        "type": "bool"
      },
      {
        "name": "rec_drug_c",
        "type": "bool"
      }
    ],
    "rules": [
      {
        "id": "rec_c_from_renal_impairment",
        "priority": 40,
        "when": {
          "var": "renal_impairment"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_c_from_anticoagulated",
        "priority": 40,
        "when": {
          "var": "anticoagulated"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_a_from_conjunction",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "polypharmacy"
            },
            {
              "var": "heart_failure"
            },
            {
              "var": "elderly"
            }
          ]
        },
        "then": [
          {
            "var": "rec_drug_a",
            "value": true
          }
        ]
      },
      {
        "id": "rec_c_from_qt_prolongation",
        "priority": 40,
        "when": {
          "var": "qt_prolongation"
        },
        "then": [
          {
            "var": "rec_drug_c",
            "value": true
          }
        ]
      },
      {
        "id": "rec_b_from_trigger",
        "priority": 50,
        "when": {
          "var": "polypharmacy"
        },
        "then": [
          {
            "var": "rec_drug_b",
            "value": true
          }
        ]
      }
    ],
    "default": [
      {
        "var": "rec_drug_a",
        "value": false
      },
      {
        "var": "rec_drug_b",
        "value": false
      },
      {
        "var": "rec_drug_c",
        "value": false
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "no-contraindicated-pair",
    "kind": "mutual_exclusion",
    "mutual_exclusion": {
      "pairs": [
        [
          {
            "var": "rec_drug_a"
          },
          {
            "var": "rec_drug_b"
          }
        ]
      ]
    },
    "intent": "no input recommends both drug a and drug b"
  }
}
