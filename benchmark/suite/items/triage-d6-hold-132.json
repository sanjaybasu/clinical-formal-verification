{
  "id": "triage-d6-hold-132",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-6-132",
    "kind": "decision",
    "inputs": [
      {
        "name": "severe_headache",
        "type": "bool"
      },
      {
        "name": "syncope",
        "type": "bool"
      },
      {
        "name": "dyspnea",
        "type": "bool"
      },
      {
        "name": "stiff_neck",
        "type": "bool"
      },
      {
        "name": "vision_loss",
        "type": "bool"
      },
      {
        "name": "leg_swelling",
        "type": "bool"
      },
      {
        "name": "back_pain",
        "type": "bool"
      },
      {
        "name": "slurred_speech",
        "type": "bool"
      },
      {
        "name": "abdominal_pain",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_back_pain",
        "priority": 3,
        "when": {
          "var": "back_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_dyspnea",
        "priority": 2,
        "when": {
          "var": "dyspnea"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_syncope",
        "priority": 3,
        "when": {
          "var": "syncope"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_stiff_neck",
        "priority": 3,
        "when": {
          "var": "stiff_neck"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_vision_loss",
        "priority": 2,
        "when": {
          "var": "vision_loss"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_abdominal_pain",
        "priority": 2,
        "when": {
          "var": "abdominal_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_slurred_speech",
        "priority": 2,
        "when": {
          "var": "slurred_speech"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_severe_headache",
        "priority": 2,
        "when": {
          "var": "severe_headache"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "leg_swelling",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting leg_swelling true never lowers acuity"
  }
}
