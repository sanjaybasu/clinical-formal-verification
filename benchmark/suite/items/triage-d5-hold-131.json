{
  "id": "triage-d5-hold-131",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-5-131",
    "kind": "decision",
    "inputs": [
      {
        "name": "chest_pain",
        "type": "bool"
      },
      {
        "name": "fever",
        "type": "bool"
      },
      {
        "name": "slurred_speech",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "palpitations",
        "type": "bool"
      },
      {
        "name": "focal_weakness",
        "type": "bool"
      },
      {
        "name": "back_pain",
        "type": "bool"
      },
      {
        "name": "vomiting",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_slurred_speech",
        "priority": 2,
        "when": {
          "var": "slurred_speech"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_focal_weakness",
        "priority": 2,
        "when": {
          "var": "focal_weakness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_rash",
        "priority": 3,
        "when": {
          "var": "rash"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_back_pain",
        "priority": 3,
        "when": {
          "var": "back_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_fever",
        "priority": 3,
        "when": {
          "var": "fever"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_chest_pain",
        "priority": 2,
        "when": {
          "var": "chest_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_vomiting",
        "priority": 2,
        "when": {
          "var": "vomiting"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "palpitations",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting palpitations true never lowers acuity"
  }
}
