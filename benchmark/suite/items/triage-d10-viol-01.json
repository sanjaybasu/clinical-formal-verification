{
  "id": "triage-d10-viol-01",
  "domain": "triage",
  "metadata": {
    "description": "symptom-to-acuity rules; adding a red flag must not lower acuity",
    "source": "synthetic",
    "clinical_intent": "no red-flag symptom, once present, may lower the assigned acuity"
  },
  "ruleset": {
    "id": "triage-10-1",
    "kind": "decision",
    "inputs": [
      {
        "name": "dizziness",
        "type": "bool"
      },
      {
        "name": "confusion",
        "type": "bool"
      },
      {
        "name": "back_pain",
        "type": "bool"
      },
      {
        "name": "hemoptysis",
        "type": "bool"
      },
      {
        "name": "chest_pain",
        "type": "bool"
      },
      {
        "name": "vomiting",
        "type": "bool"
      },
      {
        "name": "dyspnea",
        "type": "bool"
      },
      {
        "name": "focal_weakness",
        "type": "bool"
      },
      {
        "name": "sweating",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "slurred_speech",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "acuity",
        "type": "enum",
        "domain": [
          "self_care",
          "routine",
          "urgent",
          "emergent"
        ]
      }
    ],
    "rules": [
      {
        "id": "raise_chest_pain",
        "priority": 2,
        "when": {
          "var": "chest_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_focal_weakness",
        "priority": 3,
        "when": {
          "var": "focal_weakness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_vomiting",
        "priority": 3,
        "when": {
          "var": "vomiting"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_hemoptysis",
        "priority": 3,
        "when": {
          "var": "hemoptysis"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      },
      {
        "id": "raise_back_pain",
        "priority": 2,
        "when": {
          "var": "back_pain"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "interaction_drop",
        "priority": 100,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "dizziness"
            },
            {
              "var": "confusion"
            },
            {
              "var": "back_pain"
            },
            {
              "var": "hemoptysis"
            },
            {
              "var": "chest_pain"
            },
            {
              "var": "vomiting"
            },
            {
              "var": "dyspnea"
            },
            {
              "var": "focal_weakness"
            },
            {
              "var": "sweating"
            },
            {
              "var": "rash"
            }
          ]
        },
        "then": [
          {
            "var": "acuity",
            "value": "self_care"
          }
        ]
      },
      {
        "id": "raise_dizziness",
        "priority": 2,
        "when": {
          "var": "dizziness"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_dyspnea",
        "priority": 2,
        "when": {
          "var": "dyspnea"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_sweating",
        "priority": 2,
        "when": {
          "var": "sweating"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_slurred_speech",
        "priority": 2,
        "when": {
          "var": "slurred_speech"
        },
        "then": [
          {
            "var": "acuity",
            "value": "urgent"
          }
        ]
      },
      {
        "id": "raise_confusion",
        "priority": 3,
        "when": {
          "var": "confusion"
        },
        "then": [
          {
            "var": "acuity",
            "value": "emergent"
          }
        ]
      }
    ],
    "default": [
      {
        "var": "acuity",
        "value": "routine"
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "redflag-never-lowers-acuity",
    "kind": "monotonicity",
    "monotonicity": {
      "perturbation": {
        "var": "rash",
        "change": "set_true"
      },
      "monotone_var": "acuity",
      "direction": "nondecreasing"
    },
    "intent": "setting rash true never lowers acuity"
  }
}
