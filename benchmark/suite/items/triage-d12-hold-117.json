    "id": "triage-12-117",
    "kind": "decision",
    "inputs": [
      {
        "name": "chest_pain",
        "type": "bool"
      },
      {
        "name": "rash",
        "type": "bool"
      },
      {
        "name": "abdominal_pain",
        "type": "bool"
      },
      {
        "name": "back_pain",
        "type": "bool"
      },
      {
        "name": "dizziness",
        "type": "bool"
      },
      {
        "name": "slurred_speech",
        "type": "bool"
      },
      {
        "name": "stiff_neck",
        "type": "bool"
      },
      {
