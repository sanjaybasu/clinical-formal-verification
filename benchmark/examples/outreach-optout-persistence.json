{
  "id": "outreach-optout-persistence",
  "domain": "outreach",
  "metadata": {
    "description": "messaging state machine; no message is sent after an opt-out",
    "source": "synthetic",
    "clinical_intent": "once a member opts out of outreach, the program must never send another message regardless of subsequent events"
  },
  "ruleset": {
    "id": "outreach-optout-v1",
    "kind": "transition_system",
    "state_vars": [
      { "name": "opted_out", "type": "bool" },
      { "name": "sent", "type": "bool" }
    ],
    "events": [
      { "name": "optout" },
      { "name": "send_attempt" },
      { "name": "tick" }
    ],
    "init": [
      { "var": "opted_out", "value": false },
      { "var": "sent", "value": false }
    ],
    "transitions": [
      { "id": "t_optout", "event": "optout", "update": [ { "var": "opted_out", "expr": { "const": true } }, { "var": "sent", "expr": { "const": false } } ] },
      { "id": "t_send_allowed", "event": "send_attempt", "guard": { "op": "not", "args": [ { "var": "opted_out" } ] }, "update": [ { "var": "sent", "expr": { "const": true } } ], "emits": [ { "action": "send_message" } ] },
      { "id": "t_send_blocked", "event": "send_attempt", "guard": { "var": "opted_out" }, "update": [ { "var": "sent", "expr": { "const": false } } ] },
      { "id": "t_tick", "event": "tick", "update": [ { "var": "sent", "expr": { "const": false } } ] }
    ]
  },
  "property": {
    "id": "no-send-after-optout",
    "kind": "temporal",
    "formula": { "op": "G", "args": [ { "op": "implies", "args": [ { "var": "opted_out" }, { "op": "not", "args": [ { "var": "sent" } ] } ] } ] },
    "bound": 8,
    "intent": "on every reachable trace, in every state where opted_out is true the sent flag is false"
  }
}
