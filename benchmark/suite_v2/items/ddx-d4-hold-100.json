{
  "id": "ddx-d4-hold-100",
  "domain": "differential_breadth",
  "metadata": {
    "description": "differential breadth; a can't-miss differential is not omitted under red flags",
    "source": "synthetic",
    "clinical_intent": "with dissection red flags present, aortic dissection stays in the differential"
  },
  "ruleset": {
    "id": "dx-4-100",
    "kind": "decision",
    "inputs": [
      {
        "name": "pulse_deficit",
        "type": "bool"
      },
      {
        "name": "tearing_chest_pain",
        "type": "bool"
      },
      {
        "name": "widened_mediastinum",
        "type": "bool"
      },
      {
        "name": "hypertension",
        "type": "bool"
      }
    ],
    "outputs": [
      {
        "name": "ddx_aortic_dissection",
        "type": "bool"
      }
    ],
    "rules": [
      {
        "id": "include_dissection",
        "priority": 50,
        "when": {
          "op": "and",
          "args": [
            {
              "var": "pulse_deficit"
            },
            {
              "var": "tearing_chest_pain"
            },
            {
              "var": "widened_mediastinum"
            },
            {
              "var": "hypertension"
            }
          ]
        },
        "then": [
          {
            "var": "ddx_aortic_dissection",
            "value": true
          }
        ]
      }
    ],
    "default": [
      {
        "var": "ddx_aortic_dissection",
        "value": false
      }
    ],
    "conflict_resolution": "priority"
  },
  "property": {
    "id": "cant-miss-differential-not-omitted",
    "kind": "invariant",
    "formula": {
      "op": "implies",
      "args": [
        {
          "op": "and",
          "args": [
            {
              "var": "pulse_deficit"
            },
            {
              "var": "tearing_chest_pain"
            },
            {
              "var": "widened_mediastinum"
            },
            {
              "var": "hypertension"
            }
          ]
        },
        {
          "var": "ddx_aortic_dissection"
        }
      ]
    },
    "intent": "when red-flag antecedents hold, the can't-miss differential is present"
  }
}
